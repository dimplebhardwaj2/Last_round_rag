# LAST ROUND — environment
# Get a FREE Groq API key at https://console.groq.com/keys
GROQ_API_KEY_1=your_primary_groq_api_key_here
GROQ_API_KEY_2=your_backup_groq_api_key_here
GROQ_API_KEY_3=your_second_backup_groq_api_key_here

# Backward-compatible single-key form. Leave blank if using numbered keys.
GROQ_API_KEY=
# Model used for the interviewer + grading (Groq free tier).
# Strong:  llama-3.3-70b-versatile   |   Fast/cheap: llama-3.1-8b-instant
LR_MODEL=llama-3.1-8b-instant

# How many candidate answers before the interview wraps up.
LR_MAX_QUESTIONS=6
